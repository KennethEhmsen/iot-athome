// IoT-AtHome plugin host ABI.
//
// Versioned per ADR-0003: major bumps are breaking, minor bumps are
// additive only. The host supports the latest major + one previous
// for at least one full major cycle.
//
// Every host call is mediated by the plugin's declared capabilities
// (plugin-manifest.schema.json). A plugin that calls `bus-publish`
// on a subject outside its `bus.publish` allow-list gets a
// capability-denied error at host-call time — not at load time.

// Additive minor bumps:
//   1.1.0 — mqtt host interface + on-mqtt-message runtime export
//           (ADR-0013, M2 W4).
//   1.2.0 — registry host interface (transitional per ADR-0013);
//           deprecated in M4 once M3 W1.2's registry bus-watcher
//           shipped.
//   1.4.0 — net host interface: outbound HTTP for plugins that poll
//           external APIs (weather, energy tariffs, calendar,
//           notification sinks, HTTP-based device APIs). Manifest
//           declares URL prefixes via `capabilities.net.outbound`;
//           the host enforces an exact-prefix match before issuing
//           the request. Additive — 1.3.0 plugins still load.
//
// Breaking-change major bumps:
//   1.3.0 — removes the `registry` host interface. M3 W1.2's
//           registry bus-watcher auto-registers any (integration,
//           external_id) pair that surfaces on `device.>`; the
//           explicit `registry::upsert-device` capability is now
//           redundant. M4 shipped a one-shot deprecation warn from
//           the host; M5a removes the import. Adapter plugins that
//           still want to ensure registration "before first state
//           publish" simply publish state — the registry catches up.
//
// Note: per ADR-0003 a host supports the latest major + one
// previous for a major cycle. 1.2.0 plugins targeting `import
// registry` are NOT loadable under a 1.3.0 host — there's no
// minor-version compatibility story for capability removal.
package iot:plugin-host@1.4.0;

interface types {
    /// Dotted-namespace stable error code (see ADR-0008).
    /// Examples: "capability.denied", "bus.subject.invalid".
    type error-code = string;

    record plugin-error {
        code: error-code,
        message: string,
    }

    /// Opaque byte string. Plugins Protobuf-encode iot.device.v1 messages.
    type payload = list<u8>;
}

/// Bus: publish typed messages on NATS subjects. Subscription support
/// lands in a later minor (1.1+) once the first plugin needs it.
interface bus {
    use types.{plugin-error, payload};

    /// Publish `payload` on `subject` with `iot-type` set as a bus header.
    ///
    /// Capability check: `subject` must match one of the plugin manifest's
    /// `capabilities.bus.publish` patterns.
    ///
    /// `iot-type` is the fully-qualified Protobuf type name, e.g.
    /// `iot.device.v1.EntityState`.
    publish: func(
        subject: string,
        iot-type: string,
        payload: payload,
    ) -> result<_, plugin-error>;
}

/// Structured logging. The host routes these through its tracing
/// subscriber so plugin logs join the host's span tree.
interface log {
    enum level { trace, debug, info, warn, error }
    emit: func(level: level, target: string, message: string);
}

// (Removed in 1.3.0 — see package-level breaking-change note above.)
// The `registry` host interface previously offered an `upsert-device`
// function that wrapped the host-side tonic gRPC client. M3 W1.2
// shipped a registry bus-watcher that auto-registers any unknown
// `(integration, external_id)` pair on the `device.>` subject space,
// which makes the explicit upsert call redundant. Plugins migrate by
// dropping the `registry` import + the manifest's
// `capabilities.registry.upsert` flag; publishing on `device.<id>.state`
// is enough to register the device.

/// MQTT: the host owns one broker connection and multiplexes subscribe/
/// publish across plugins. Plugins never see the broker socket or TLS
/// material. Per ADR-0013, this is how the z2m adapter (and future
/// MQTT-speaking adapters like Z-Wave / 433-SDR) consume the broker
/// without needing tokio + rumqttc inside the component.
interface mqtt {
    use types.{plugin-error, payload};

    /// Register interest in an MQTT topic filter. Inbound messages
    /// matching the filter dispatch to `runtime.on-mqtt-message`.
    /// Capability check: `filter` must be covered (under MQTT wildcard
    /// semantics) by one of `capabilities.mqtt.subscribe`.
    subscribe: func(filter: string) -> result<_, plugin-error>;

    /// Publish `payload` on `topic`. `retain` controls the MQTT retain
    /// flag (usually false; true for last-known-state semantics).
    /// Capability check: `topic` must match one of
    /// `capabilities.mqtt.publish`.
    publish: func(
        topic: string,
        payload: payload,
        retain: bool,
    ) -> result<_, plugin-error>;
}

/// Net: outbound HTTP from inside the WASM sandbox (1.4.0+).
///
/// Plugins that poll external APIs (weather, dynamic energy
/// tariffs, calendar feeds, HTTP-based device APIs like Shelly /
/// Tasmota / ESPHome native, notification sinks like ntfy.sh /
/// Pushover) declare URL prefixes in their manifest's
/// `capabilities.net.outbound` array; the host enforces an
/// exact-prefix match before issuing the request.
///
/// Implementation detail: the host runs `reqwest` with a 10 s
/// default timeout, redirects disabled, and no automatic
/// decompression. Non-2xx responses surface as `Ok(http-response)`
/// with the status code populated — plugins decide whether 4xx /
/// 5xx is an error or a "device says no" valid value. Network /
/// timeout / DNS failures surface as `Err(plugin-error)` with code
/// `net.transport`.
interface net {
    use types.{plugin-error};

    /// One outbound HTTP request. Headers as a list-of-tuples
    /// because WIT 0.2 doesn't have a list-typed map yet.
    record http-request {
        /// "GET" / "POST" / "PUT" / "PATCH" / "DELETE". Case-
        /// insensitive on the wire; the host normalises.
        method: string,
        /// Full URL including scheme, host, and any query string.
        /// Manifest URL-prefix check happens here.
        url: string,
        /// Request headers. Empty list = no headers beyond
        /// reqwest's defaults (User-Agent, Accept-Encoding identity).
        headers: list<tuple<string, string>>,
        /// Optional request body. None for bodyless verbs (GET,
        /// HEAD), Some for POST/PUT/PATCH.
        body: option<list<u8>>,
    }

    record http-response {
        /// HTTP status. 0 only when transport itself failed —
        /// in that case the host returns Err and never produces
        /// http-response anyway.
        status: u16,
        /// Response headers. Decoded via reqwest's HeaderMap iter.
        headers: list<tuple<string, string>>,
        /// Body bytes. Empty list when the response has no body
        /// (e.g. 204, HEAD).
        body: list<u8>,
    }

    /// Issue one HTTP request.
    ///
    /// Capability check: `req.url` must start with one of the
    /// plugin manifest's `capabilities.net.outbound` URL prefixes.
    /// Anything outside the allow-list returns Err with code
    /// `capability.denied`.
    http: func(req: http-request) -> result<http-response, plugin-error>;
}

/// Exports a plugin must implement.
///
/// Grouping under an interface (rather than leaving as world-level free
/// functions) makes wit-bindgen emit a single `__export_world_plugin_cabi`
/// macro; two world-level exports produce a duplicate-name error.
interface runtime {
    use types.{plugin-error, payload};

    /// Called once, after capabilities are verified and the plugin is
    /// loaded. Blocks the host's load routine; long-running work should
    /// be spawned via future `tasks` (1.1+).
    init: func() -> result<_, plugin-error>;

    /// Called on every incoming bus message matching the plugin's
    /// `capabilities.bus.subscribe` patterns. 1.1+ will add a stream
    /// variant; for 1.0 the host calls once per message.
    on-message: func(
        subject: string,
        iot-type: string,
        payload: payload,
    ) -> result<_, plugin-error>;

    /// Called on every incoming MQTT message whose topic matches a
    /// filter the plugin registered via `mqtt.subscribe`. Added in
    /// 1.1.0 (ADR-0013).
    on-mqtt-message: func(
        topic: string,
        payload: payload,
    ) -> result<_, plugin-error>;
}

/// The world a plugin imports from + exports to the host.
world plugin {
    import bus;
    import log;
    import mqtt;
    import net;
    export runtime;
}
