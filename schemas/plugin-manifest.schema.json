{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iot-athome.dev/schemas/plugin-manifest.schema.json",
  "title": "IoT-AtHome Plugin Manifest",
  "description": "Single source of truth for plugin identity, ABI version, runtime, resource limits, signing, and capabilities. See ADR-0003, ADR-0004, ADR-0006.",
  "type": "object",
  "required": ["schema_version", "id", "version", "runtime", "abi", "entrypoint", "capabilities", "resources", "signatures"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Manifest schema version. Bumped on breaking changes to THIS schema."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,62}[a-z0-9]$",
      "description": "Globally unique plugin id. Lowercase, kebab-case."
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "description": "SemVer. MUST match the artifact file name."
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "authors": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "homepage": { "type": "string", "format": "uri" },
    "license": {
      "type": "string",
      "description": "SPDX identifier."
    },

    "runtime": {
      "type": "string",
      "enum": ["wasm-component", "oci-container"],
      "description": "Execution sandbox. WASM is the default; OCI is the escape hatch for HW drivers."
    },
    "abi": {
      "type": "object",
      "required": ["world", "version"],
      "additionalProperties": false,
      "properties": {
        "world": {
          "type": "string",
          "enum": ["iot:plugin-host"],
          "description": "WIT world the plugin targets."
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "WIT world version."
        }
      }
    },
    "entrypoint": {
      "type": "string",
      "description": "Relative path inside the plugin bundle (e.g. 'plugin.wasm' or 'image.tar')."
    },

    "capabilities": {
      "type": "object",
      "description": "Declared capabilities. Host enforces each one at call time.",
      "additionalProperties": false,
      "properties": {
        "bus": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "publish":   { "type": "array", "items": { "$ref": "#/$defs/NatsSubjectPattern" } },
            "subscribe": { "type": "array", "items": { "$ref": "#/$defs/NatsSubjectPattern" } }
          }
        },
        "mqtt": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "publish":   { "type": "array", "items": { "$ref": "#/$defs/MqttTopicPattern" } },
            "subscribe": { "type": "array", "items": { "$ref": "#/$defs/MqttTopicPattern" } },
            "bridge":    { "type": "array", "items": { "type": "string", "format": "uri" },
                           "description": "Elevated. Requires user approval." }
          }
        },
        "net": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "outbound": {
              "type": "array",
              "items": { "type": "string", "pattern": "^(https?|mqtt|mqtts|wss?)://" }
            }
          }
        },
        "fs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read":  { "type": "array", "items": { "type": "string" } },
            "write": { "type": "array", "items": { "type": "string" } }
          }
        },
        "serial": {
          "type": "array",
          "items": { "type": "string", "pattern": "^/dev/tty[A-Za-z0-9]+$" },
          "description": "Elevated. Requires explicit user approval."
        },
        "ml": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "train":   { "type": "array", "items": { "type": "string" } },
            "predict": { "type": "array", "items": { "type": "string" } }
          }
        },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "capacity_guardian": {
              "type": "boolean",
              "description": "Elevated. Permits the plugin to request load-shedding actions."
            }
          }
        }
      }
    },

    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["memory_mb_max", "cpu_pct_max"],
      "properties": {
        "memory_mb_max": { "type": "integer", "minimum": 1, "maximum": 2048 },
        "cpu_pct_max":   { "type": "integer", "minimum": 1, "maximum": 100 },
        "fuel_max":      { "type": "integer", "minimum": 0, "description": "Wasmtime fuel per host-call turn. 0 = unlimited." }
      }
    },

    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["mechanism"],
        "oneOf": [
          {
            "properties": {
              "mechanism": { "const": "cosign-keyless" },
              "rekor_entry": { "type": "string", "description": "Rekor UUID" },
              "identity":    { "type": "string", "description": "OIDC identity string" },
              "issuer":      { "type": "string" }
            },
            "required": ["rekor_entry", "identity", "issuer"]
          },
          {
            "properties": {
              "mechanism": { "const": "cosign-key" },
              "keyid":     { "type": "string" },
              "sig":       { "type": "string", "description": "Base64 signature bytes" }
            },
            "required": ["keyid", "sig"]
          }
        ]
      }
    },

    "sbom": {
      "type": "string",
      "description": "Relative path inside the bundle to the CycloneDX SBOM."
    },

    "ui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tiles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "bundle"],
            "properties": {
              "id":     { "type": "string" },
              "bundle": { "type": "string", "description": "Path to signed tile bundle." },
              "size":   { "type": "array", "items": { "type": "string", "pattern": "^[0-9]+x[0-9]+$" } },
              "permissions": {
                "type": "object",
                "properties": {
                  "data":    { "type": "array", "items": { "type": "string" } },
                  "actions": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },

    "commissioning": {
      "type": "object",
      "description": "Optional: for integrations that require an install-time config (e.g. 3-phase meter CT ratios, electrician sign-off).",
      "properties": {
        "required_fields":          { "type": "array", "items": { "type": "string" } },
        "requires_elevated_user":   { "type": "boolean", "default": false },
        "requires_installer_cert":  { "type": "boolean", "default": false }
      }
    }
  },

  "$defs": {
    "NatsSubjectPattern": {
      "type": "string",
      "pattern": "^[a-z0-9_.*>-]+$",
      "description": "NATS subject (dots, alphanum, _-, *, >). See ADR-0004."
    },
    "MqttTopicPattern": {
      "type": "string",
      "pattern": "^[^#+]*([#+][^#+]*)?$",
      "description": "MQTT topic filter."
    }
  }
}
